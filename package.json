{
  "name": "vr-astronomy-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop-first, VR-ready real-imagery astronomy app (PHASE-0 + PHASE-1).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/share": "^8.0.1",
    "healpix-ts": "^1.1.0",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/three": "0.184.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "3.2.4"
  }
}
